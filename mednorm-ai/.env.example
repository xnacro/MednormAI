# MedNorm AI — Environment Variables (Team LegacyCoderz)
# Copy this file to .env and fill in your values.
# The app works fully in Demo Mode without any API keys.

# ─── OpenAI ────────────────────────────────────────────────────────────────────
# Required for live GPT-4 clinical NLP extraction.
# Leave blank to use rule-based fallback (demo mode).
OPENAI_API_KEY=sk-your-openai-api-key-here

# ─── App Config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
APP_ENV=development

# ─── (Optional) Database ───────────────────────────────────────────────────────
# Uncomment and configure if replacing the in-memory store with a real DB.
# DATABASE_URL=postgresql://user:password@localhost:5432/mednorm

# ─── (Optional) Tesseract OCR ─────────────────────────────────────────────────
# Set this if Tesseract is installed in a non-default location.
# TESSDATA_PREFIX=/usr/share/tesseract-ocr/5/tessdata
